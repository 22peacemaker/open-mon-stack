global:
  resolve_timeout: 5m

route:
  group_by: ['alertname', 'severity', 'instance']
  group_wait: 30s
  group_interval: 5m
  repeat_interval: 4h
  receiver: 'oms'

receivers:
  - name: 'oms'
    webhook_configs:
      - url: 'http://host.docker.internal:{{.OmsPort}}/api/webhooks/receiver'
        send_resolved: true
