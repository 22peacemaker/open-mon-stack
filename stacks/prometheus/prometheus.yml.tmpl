global:
  scrape_interval: 15s
  evaluation_interval: 15s

scrape_configs:
  - job_name: "prometheus"
    static_configs:
      - targets: ["localhost:9090"]

  - job_name: "node-exporter"
    static_configs:
      - targets: ["node-exporter:9100"]
{{range .ScrapeTargets}}
  - job_name: "{{.JobName}}"
    static_configs:
      - targets:{{range .Targets}}
          - "{{.}}"{{end}}
{{if .Labels}}    labels:{{range $k, $v := .Labels}}
        {{$k}}: "{{$v}}"{{end}}{{end}}
{{end}}
